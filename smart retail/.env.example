# Django
DJANGO_ENV=development
SECRET_KEY=change-this-to-a-random-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
# DB_ENGINE=postgresql or mysql — this project is currently set to MySQL below.
# Requires MySQL 5.7.8+ / 8.0+ (needed for the JSON column type used in a couple of models).
DB_ENGINE=mysql

# --- MySQL settings (active, since DB_ENGINE=mysql above) ---
DB_NAME=smartretail_db
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_HOST=localhost
DB_PORT=3306

# --- Postgres settings (uncomment these + set DB_ENGINE=postgresql above to switch back) ---
# DB_NAME=smartretail_db
# DB_USER=smartretail_user
# DB_PASSWORD=change-this-password
# DB_HOST=localhost
# DB_PORT=5432

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MIN=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Email (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=SmartRetail ERP <no-reply@smartretail.com>

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5500,http://127.0.0.1:5500,http://localhost:8080,http://127.0.0.1:8080

# Frontend URL (used in password reset / verification links)
FRONTEND_URL=http://localhost:3000
